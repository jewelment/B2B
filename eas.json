{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "API_URL": "http://localhost:3000/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "API_URL": "https://staging.b2b-portal.com/api"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "API_URL": "https://b2b-portal.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
