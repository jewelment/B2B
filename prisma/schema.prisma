// ======================================================
// 1. DATABASE CONFIGURATION
// ======================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// MULTI-TENANT ISOLATION (SAAS)
// ======================================================
model Tenant {
  id              String   @id @default(cuid())
  domain          String   @unique
  name            String
  brandPrimary    String   @default("#000000")
  viewerBackground String  @default("WHITE")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  
  // Relations to isolated data
  products        Product[]
  catalogs        Catalog[]
  users           User[]
  orders          PurchaseOrder[]
  accessRequests  AccessRequest[]
  storeSettings   StoreSettings?
  tickets         Ticket[]
  sduiPages       SduiPage[]
  analyticsEvents AnalyticsEvent[]
  productOptions  ProductOption[]
  optionSets      OptionSet[]
  
  categories      Category[]
  collections     Collection[]
  tags            Tag[]
  vendors         Vendor[]
  systemLogs      SystemLog[]
  
  // Schemes Module
  savingsSchemes  SavingsScheme[]
  enrollments     Enrollment[]
}

// ======================================================
// 2. THE CORE INVENTORY & PIM MODULE
// ======================================================

model SystemLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  user        String   // Display name (e.g. "Admin System", "John Doe")
  initials    String   // Avatar initials (e.g. "AS", "JD")
  avatarColor String   // Tailwind class for the avatar styling
  module      String   // E.g., 'ORDERS', 'INVENTORY', 'CRM'
  activity    String   // Description (e.g., 'Generated draft PO-20260722-1405.')
  
  createdAt   DateTime @default(now())
}

model AccessRequest {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  gstin     String
  salesCode String?
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}

model Product {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  handle         String  
  designCode     String  
  title          String
  description    String?
  category       String? // Core field for template generation
  
  // Pricing & Inventory Core
  price          Float   @default(0) 
  compareAtPrice Float?
  weightGrams    Float?
  
  // Legacy Core Fields
  metalPurity    String?
  grossWeight    Float?
  pureWeight     Float?
  igiCertNumber  String?
  estimatedPrice Float?  @default(0)

  status         String  @default("DRAFT")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // RELATIONS
  components        Component[]
  customFieldValues ProductFieldValue[] // Links to dynamic custom attributes
  media             ProductMedia[]      // The localized Asset Pipeline
  
  categoryId        String?
  categoryModel     Category?           @relation("ProductToCategory", fields: [categoryId], references: [id])

  collectionId      String?
  collectionModel   Collection?         @relation("ProductToCollection", fields: [collectionId], references: [id])

  vendorId          String?
  vendorModel       Vendor?             @relation("ProductToVendor", fields: [vendorId], references: [id])

  productTags       ProductTag[]

  optionSets        ProductOptionSet[]
  variants          ProductVariant[]

  @@unique([tenantId, handle])
  @@unique([tenantId, designCode])
}

model Component {
  id        String  @id @default(cuid())
  productId String
  type      String  // e.g., "Metal", "Diamond", "Making Charges"
  details   String
  weight    Float?
  rate      Float
  finalCost Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// PRODUCT INFORMATION MANAGEMENT (PIM) ENGINE
// ------------------------------------------------------

model CustomField {
  id          String              @id @default(cuid())
  name        String              @unique // e.g., "Diamond pcs", "Offer text"
  dataType    String              // "TEXT", "NUMBER", "URL", "JSON"
  isMandatory Boolean             @default(false)
  options     String?             
  createdAt   DateTime            @default(now())
  
  values      ProductFieldValue[]
}

model ProductFieldValue {
  id            String      @id @default(cuid())
  productId     String
  fieldId       String
  value         String      
  
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  customField   CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([productId, fieldId])
}

model ProductMedia {
  id          String   @id @default(cuid())
  productId   String
  url         String   // Local server path (e.g., /uploads/SKU_1.jpg)
  isPrimary   Boolean  @default(false)
  sequence    Int      @default(0) // 1, 2, 3 based on regex matching
  color       String?  // Associated variant color

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ======================================================
// 3. THE FLIPBOOK CATALOG MODULE 
// ======================================================

model Catalog {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  clientId      String?
  validUntil    DateTime?
  theme         String    @default("LIGHT")
  itemsPerPage  Int       @default(4)
  configuration String?   // Stores advanced flipbook settings as stringified JSON
  views         Int       @default(0)
  totalOrders   Int       @default(0)
  pipelineValue Float     @default(0.0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           CatalogItem[]
  analyticsEvents AnalyticsEvent[]
}

model CatalogItem {
  id         String @id @default(cuid())
  catalogId  String
  designCode String
  sequence   Int

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@unique([catalogId, designCode])
  @@index([catalogId])
}

// ======================================================
// 4. UNIFIED B2B USERS, AUTH & CRM MODULE
// ======================================================

model User {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String? // Added for UI/CRM mapping
  email           String  
  passwordHash    String
  companyName     String?

  contactName     String?
  gstin           String? // Standardized to match registration API
  phone           String?
  phoneNumber     String? // Fallback for Next-Auth UI

  role            String  @default("CLIENT")  // "ADMIN", "SALES", "CLIENT"
  status          String  @default("PENDING") // "PENDING", "APPROVED", "SUSPENDED"
  referralCode    String?
  isApproved      Boolean @default(false) 

  businessType    String? 
  yearEstablished Int?

  // CRM Mapping: Links a Business Owner to a specific Sales Rep
  assignedSalesmanId String?
  salesman           User?   @relation("SalesToClient", fields: [assignedSalesmanId], references: [id])
  clients            User[]  @relation("SalesToClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RELATIONS
  orders    PurchaseOrder[]
  contacts  ContactPerson[]
  addresses Address[]
  
  reportedTickets Ticket[] @relation("ReportedTickets")
  assignedTickets Ticket[] @relation("AssignedTickets")
  ticketMessages  TicketMessage[]
  analyticsEvents AnalyticsEvent[]
  
  // Schemes Module
  enrollments     Enrollment[]

  @@unique([tenantId, email])
}

model ContactPerson {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String
  designation String?
  email       String?
  mobile      String?
  whatsapp    String?
  isPrimary   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String  // "BILLING" or "SHIPPING"
  country     String?
  state       String?
  city        String?
  zipCode     String?
  fullAddress String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ======================================================
// 5. THE B2B GLOBAL PURCHASE ORDER MATRIX (PHASE 4)
// ======================================================

model PurchaseOrder {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  poNumber    String   
  catalogId   String?  // Maps to the Flipbook they ordered from
  
  clientId    String
  client      User     @relation(fields: [clientId], references: [id])
  
  createdBy   String?
  totalUnits  Int
  totalAmount Float
  status      String   @default("PENDING") // PENDING, PROCESSING, FULFILLED
  notes       String?
  matrixData  String?  // Stores the 2D B2B matrix payload as JSON

  items       OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, poNumber])
}

model OrderItem {
  id         String        @id @default(cuid())
  orderId    String
  order      PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  designCode String
  purity     String
  size       String
  quantity   Int
  unitPrice  Float
  totalPrice Float
}

// ======================================================
// 6. PRICING CONTROL MODULE 
// ======================================================

model StoreSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pricingMode       String   @default("MANUAL")
  manualGoldRate24K Float    @default(7250.0)
  manualSilverRate  Float    @default(88.0)
  
  // Media Configuration
  enableSecureMediaProxy Boolean @default(true)
  enableWebpOptimization Boolean @default(false)
  
  // Branding Assets
  logoLight         String?
  logoDark          String?
  faviconLight      String?
  faviconDark       String?

  // SEO Text Branding
  brandName         String?
  brandDescription  String?
  brandSubheading   String?

  // Typography
  primaryFont       String   @default("Inter")
  secondaryFont     String   @default("Inter")
  
  // V3 Theme Builder JSON (SDUI)
  layoutData        String?  @db.Text
  
  updatedAt         DateTime @updatedAt
}

model SduiPage {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  title       String
  path        String   // e.g., "/home", "/about"
  platform    String   @default("WEB") // "WEB" or "APP"
  layoutData  String?  @db.Text
  
  environment String   @default("DRAFT") // DRAFT, DEVELOPMENT, STAGING, PRODUCTION
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, platform, path])
}

// ======================================================
// 7. AGILE TICKETING & DEVELOPMENT HUB (PHASE 12)
// ======================================================

model Ticket {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  title       String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  type        String   @default("BUG") // BUG, FEATURE, QUESTION

  // Trello Cross-Channel Features
  dueDate     DateTime?
  labels      String?  // Will store JSON array of selected tags/labels
  attachments TicketAttachment[]
  messages    TicketMessage[]

  // Reporter
  clientId    String
  client      User     @relation("ReportedTickets", fields: [clientId], references: [id], onDelete: Cascade)

  // Assigned Developer / Admin
  assigneeId  String?
  assignee    User?    @relation("AssignedTickets", fields: [assigneeId], references: [id])


  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  url       String
  filename  String
  fileSize  Int?

  createdAt DateTime @default(now())
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  content   String
  isInternal Boolean @default(false) // If true, only admins can see this message

  createdAt DateTime @default(now())
}

// ======================================================
// 8. V2: FLIPBOOK ANALYTICS & TELEMETRY (PHASE 12)
// ======================================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  catalogId String?
  catalog   Catalog? @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  eventType   String  // e.g., "CATALOG_VIEW", "PAGE_TURN", "ADD_TO_CART", "CHECKOUT"
  eventData   String? // JSON string for tracking specifics (e.g. pageNumber, designCode)
  
  createdAt   DateTime @default(now())
}

// ======================================================
// 9. PARAMETERS & OPTIONS (PHASE 2)
// ======================================================

model ProductOption {
  id                    String   @id @default(cuid())
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  optionName            String
  frontendName          String
  inputFieldType        String   @default("Drop-Down List")
  includeInFilters      Boolean  @default(false)
  includeInPriceMaster  Boolean  @default(false)

  values                OptionValue[]
  optionSets            OptionSetItem[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([tenantId, optionName])
}

model OptionValue {
  id          String   @id @default(cuid())
  optionId    String
  option      ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  name        String
  parentId    String?
  parent      OptionValue?  @relation("NestedValues", fields: [parentId], references: [id])
  children    OptionValue[] @relation("NestedValues")
  variantValues VariantOptionValue[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OptionSet {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  title           String
  isSingleVariant Boolean  @default(false)

  items           OptionSetItem[]
  productSets     ProductOptionSet[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OptionSetItem {
  id          String   @id @default(cuid())
  optionSetId String
  optionSet   OptionSet @relation(fields: [optionSetId], references: [id], onDelete: Cascade)
  
  optionId    String
  option      ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  
  // Can store JSON array of selected OptionValue IDs or structured settings
  selectedValuesJson String? 

  @@unique([optionSetId, optionId])
}

// ======================================================
// 10. CATEGORIES, COLLECTIONS, TAGS, VENDORS
// ======================================================

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  handle      String
  description String?
  
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  products    Product[]  @relation("ProductToCategory")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([tenantId, handle])
}

model Collection {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  handle      String
  description String?

  products    Product[] @relation("ProductToCollection")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([tenantId, handle])
}

model Tag {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String

  products    ProductTag[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
}

model ProductTag {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
}

model Vendor {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  email       String?
  phone       String?

  products    Product[] @relation("ProductToVendor")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ======================================================
// 11. PRODUCT VARIANTS (AUTO-GENERATED MATRIX)
// ======================================================

model ProductOptionSet {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  optionSetId String
  optionSet   OptionSet @relation(fields: [optionSetId], references: [id], onDelete: Cascade)

  @@unique([productId, optionSetId])
}

model ProductVariant {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku            String?   // E.g., RING-18K-VVS-12
  price          Float     @default(0)
  compareAtPrice Float?
  weightGrams    Float?
  
  status         String    @default("ACTIVE") // ACTIVE, DRAFT
  
  optionValues   VariantOptionValue[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model VariantOptionValue {
  id            String         @id @default(cuid())
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  optionValueId String
  optionValue   OptionValue    @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

// ======================================================
// 12. MARKETING & MERCHANDISING
// ======================================================

model Banner {
  id              String   @id @default(cuid())
  title           String
  imageUrl        String
  mobileImageUrl  String?
  linkUrl         String?
  placement       String   @default("HERO")
  status          String   @default("ACTIVE")
  tenantId        String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ======================================================
// 13. SCHEMES & ENROLLMENTS (SAVINGS MODULE)
// ======================================================

model SavingsScheme {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name                String
  status              String   @default("DRAFT") // DRAFT, ACTIVE, INACTIVE
  
  // Financials
  totalTenureMonths   Int      @default(12)
  bonusInstallments   Int      @default(1)
  shortDescription    String?
  minInstallment      Float    @default(1000)
  maxInstallment      Float    @default(100000)
  bonusDiscountPct    Float    @default(100.0)
  gracePeriodDays     Int      @default(7)

  // JSON fields for complex data
  termsAndConditions  String?  @db.Text
  faqs                String?  @db.Text // JSON Array of Q&A
  
  // Media
  desktopBannerUrl    String?
  mobileBannerUrl     String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  enrollments         Enrollment[]
}

model Enrollment {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  schemeId            String
  scheme              SavingsScheme @relation(fields: [schemeId], references: [id])
  
  clientId            String
  client              User     @relation(fields: [clientId], references: [id])
  
  monthlyInstallment  Float
  status              String   @default("ACTIVE") // ACTIVE, MATURED, CLOSED
  totalPaid           Float    @default(0)
  
  startDate           DateTime @default(now())
  maturityDate        DateTime?
  
  autoReminders       Boolean  @default(true)
  
  installments        Installment[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Installment {
  id                  String   @id @default(cuid())
  enrollmentId        String
  enrollment          Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  
  monthNumber         Int
  amount              Float
  dueDate             DateTime
  status              String   @default("PENDING") // PENDING, PAID, OVERDUE, BONUS
  paidDate            DateTime?
  transactionId       String?
  receiptUrl          String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}